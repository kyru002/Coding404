# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/coding404?retryWrites=true&w=majority

# Email Configuration (Gmail recommended)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Server Port
PORT=5000
NODE_ENV=development

# Admin moderation user (se crea/actualiza al iniciar backend)
ADMIN_USERNAME=admin404
ADMIN_EMAIL=admin@coding404.dev
ADMIN_FULL_NAME=Administrador Coding 404
ADMIN_PROGRAMMER_TYPE=Administración
ADMIN_PASSWORD=Admin404A
